{
  "name": "pi-audio-feedback",
  "version": "0.1.0",
  "description": "Audio feedback cues for the Pi TUI coding agent",
  "type": "module",
  "exports": "./src/index.ts",
  "files": [
    "src",
    "assets/wav",
    "scripts/play-wav.ps1",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "assets:generate": "tsx scripts/assets/generate.ts",
    "assets:verify": "tsx scripts/assets/verify.ts",
    "assets:verify:reproduce": "tsx scripts/assets/verify-reproduction.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:acceptance": "vitest run tests/privacy.test.ts tests/package-install.test.ts tests/platform-adapters.test.ts"
  },
  "keywords": [
    "pi-package"
  ],
  "author": "Derek Luciani",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/derekluciani/pi-audio-feedback.git"
  },
  "homepage": "https://github.com/derekluciani/pi-audio-feedback",
  "bugs": {
    "url": "https://github.com/derekluciani/pi-audio-feedback/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.80.6",
    "@earendil-works/pi-tui": "0.80.6",
    "@types/node": "^20.19.33",
    "@web-kits/audio": "0.1.0",
    "ajv": "8.20.0",
    "eslint": "9.39.2",
    "node-web-audio-api": "1.0.9",
    "prettier": "3.9.0",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "typescript-eslint": "8.54.0",
    "vitest": "3.2.7"
  },
  "pi": {
    "extensions": [
      "./src"
    ],
    "image": "https://raw.githubusercontent.com/derekluciani/pi-audio-feedback/main/assets/media/banner.webp",
    "video": "https://youtu.be/HLmf6yvpm7g",
    "compatibility": {
      "@earendil-works/pi-coding-agent": ">=0.80.6 <1.0.0"
    }
  }
}
